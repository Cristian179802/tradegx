{
  "expo": {
    "name": "TradeGx",
    "slug": "tradegx",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tradegx",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#09090b",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tradegx.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tradegx.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://www.tradegx.com"
    }
  }
}
