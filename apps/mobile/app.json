{
  "expo": {
    "name": "TradeGx",
    "slug": "tradegx",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tradegx",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#09090b",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tradegx.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tradegx.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#09090b",
          "imageWidth": 220
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "https://www.tradegx.com",
      "router": {},
      "eas": {
        "projectId": "f8920b01-76c7-475e-a14e-f8292220fa00"
      }
    },
    "owner": "cristianpp"
  }
}
