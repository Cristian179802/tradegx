# ============================================================
# DATABASE
# ============================================================
# PostgreSQL connection string (Neon, Supabase, Railway, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/apex_trader"

# ============================================================
# NEXTAUTH
# ============================================================
# App URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"
# Secret: generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# ============================================================
# OAUTH — GOOGLE
# ============================================================
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================================
# EMAIL — RESEND
# ============================================================
# Get key at: https://resend.com
RESEND_API_KEY=""
# From address (must be a verified domain in Resend)
RESEND_FROM_EMAIL="noreply@apextrader.io"

# ============================================================
# FILE STORAGE — CLOUDINARY
# ============================================================
# Get credentials at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ============================================================
# PAYMENTS — STRIPE
# ============================================================
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_PRO_ANNUAL_PRICE_ID=""

# ============================================================
# BROKER SYNC — METAAPI
# ============================================================
# Get token at: https://metaapi.cloud
METAAPI_TOKEN=""

# ============================================================
# AI COACH
# ============================================================
# Anthropic Claude API key: https://console.anthropic.com
ANTHROPIC_API_KEY=""
# OpenAI fallback: https://platform.openai.com
OPENAI_API_KEY=""

# ============================================================
# MARKET DATA
# ============================================================
# TwelveData API key: https://twelvedata.com
TWELVEDATA_API_KEY=""
# Finnhub API key: https://finnhub.io
FINNHUB_API_KEY=""

# ============================================================
# REDIS (for BullMQ background jobs)
# ============================================================
# Upstash Redis: https://upstash.com
REDIS_URL=""
REDIS_TOKEN=""

# ============================================================
# APP CONFIG
# ============================================================
# Set to "production" in prod
NODE_ENV="development"
# App URL for emails and links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
